generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  name            String
  college         String?
  branch          String?
  graduationYear  Int?
  avatarUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile            Profile?
  placementScores    PlacementScore[]
  interviewSessions  InterviewSession[]
  codingSubmissions  CodingSubmission[]
  codingSessions     CodingSession[]
  roadmaps           Roadmap[]
  gapAnalyses        GapAnalysis[]
  resumes            Resume[]
  userActivities     UserActivity[]
  assessmentAttempts AssessmentAttempt[]
  roadmapConversations RoadmapConversation[]
}

model Profile {
  id              String  @id @default(uuid())
  userId          String  @unique
  currentLevel    String?
  targetCompany   String?
  leetcodeUsername String?
  githubUsername  String?
  linkedinUrl     String?
  bio             String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlacementScore {
  id            String   @id @default(uuid())
  userId        String
  aptitude      Float
  dsa           Float
  coreSubjects  Float
  communication Float
  resumeScore   Float
  overall       Float
  calculatedAt  DateTime @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyChances CompanyChance[]
}

model CompanyChance {
  id            String @id @default(uuid())
  scoreId       String
  companyName   String
  chancePercent Float

  placementScore PlacementScore @relation(fields: [scoreId], references: [id], onDelete: Cascade)
}

model InterviewSession {
  id           String   @id @default(uuid())
  userId       String
  type         String   // HR | TECHNICAL | MANAGER
  company      String?
  duration     Int      // seconds
  overallScore Float?
  fillerCount  Int      @default(0)
  fillerDetail Json?    // { umm: 0, ah: 0, like: 0 }
  wpm          Float?
  transcript   String?
  feedback     Json?
  createdAt    DateTime @default(now())

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewMessages InterviewMessage[]
}

model InterviewMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String   // AI | USER
  content   String
  timestamp DateTime @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Problem {
  id                String   @id @default(uuid())
  title             String
  description       String
  difficulty        String   // Easy | Medium | Hard
  topic             String
  companyTags       String[] @default([])
  solutionApproach  String?
  optimalComplexity Json?    // { time: "O(n)", space: "O(n)" }
  starterCode       Json?    // { python: "...", java: "...", cpp: "...", javascript: "...", c: "..." }
  examples          Json?    // [{ input, output, explanation }]
  constraints       String[] @default([])
  funcSignature     Json?    // { python: "def twoSum(nums, target):", java: "public int[] twoSum(int[] nums, int target)", ... }
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  testCases         TestCase[]
  codingSubmissions CodingSubmission[]
}

model TestCase {
  id              String  @id @default(uuid())
  problemId       String
  input           String
  expectedOutput  String
  isHidden        Boolean @default(false)
  orderIndex      Int     @default(0)
  description     String? // what this test case validates

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
}

model CodingSession {
  id           String    @id @default(uuid())
  userId       String
  type         String    // PRACTICE | COMPANY_ROUND | TIMED
  company      String?
  difficulty   String?
  title        String?
  duration     Int?      // minutes (for timed sessions)
  status       String    @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED | TIMEOUT
  score        Int?
  totalScore   Int?
  problemCount Int?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions CodingSubmission[]

  @@index([userId, status])
  @@index([userId, startedAt])
}

model CodingSubmission {
  id              String   @id @default(uuid())
  userId          String
  problemId       String
  sessionId       String?
  code            String
  language        String   // python | java | cpp | javascript | c
  passedTestCases Int      @default(0)
  totalTestCases  Int      @default(0)
  score           Float?
  executionTime   Float?   // average execution time in ms
  memoryUsage     Float?   // peak memory usage in KB
  status          String   @default("PENDING") // PENDING | RUNNING | ACCEPTED | WRONG_ANSWER | ERROR | TIMEOUT
  errorMessage    String?
  testCaseResults Json?    // [{ testCaseId, passed, actualOutput, executionTime, index }]
  aiFeedback      Json?    // { suggestions, optimized_approach, style_issues, edge_cases, timeComplexity, spaceComplexity, codeQuality }
  submittedAt     DateTime @default(now())

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem       @relation(fields: [problemId], references: [id], onDelete: Cascade)
  session CodingSession? @relation(fields: [sessionId], references: [id])

  @@index([userId, submittedAt])
  @@index([problemId])
}

model Roadmap {
  id              String   @id @default(uuid())
  userId          String
  targetCompany   String
  currentLevel    String
  dailyHours      Int
  startDate       DateTime
  endDate         DateTime
  overallProgress Float    @default(0)
  createdAt       DateTime @default(now())

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeks RoadmapWeek[]
  conversations RoadmapConversation[]
}

model RoadmapWeek {
  id             String  @id @default(uuid())
  roadmapId      String
  weekNumber     Int
  phase          String  // Foundation | Core DSA | Advanced | Mock
  topic          String
  resourceCount  Int     @default(0)
  estimatedHours Float
  completed      Boolean @default(false)
  resources      Json?   // [{ title, url, type }]

  roadmap Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
}

model RoadmapConversation {
  id            String   @id @default(uuid())
  userId        String
  roadmapId     String?
  title         String
  goal          String?
  skills        String[] @default([])
  targetCompany String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmap  Roadmap?         @relation(fields: [roadmapId], references: [id], onDelete: SetNull)
  messages RoadmapMessage[]

  @@index([userId, updatedAt])
}

model RoadmapMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String   // USER | ASSISTANT
  content        String
  model          String?
  createdAt      DateTime @default(now())

  conversation RoadmapConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model GapAnalysis {
  id           String   @id @default(uuid())
  userId       String
  resumeSkills String[] @default([])
  leetcodeStats Json?    // { solved, rating, weakTopics }
  githubStats   Json?    // { repos, languages, contributions }
  missingSkills String[] @default([])
  weakAreas     String[] @default([])
  strengths     String[] @default([])
  overallMatch  Float?
  targetRole    String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id             String   @id @default(uuid())
  userId         String
  fileUrl        String?
  fileName       String?
  atsScore       Float?
  sectionScores  Json?    // { summary, skills, experience, projects, education }
  keywordsMissing String[] @default([])
  suggestions    Json?    // [{ section, bullet, suggestion }]
  actionVerbScore Float?
  uploadedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserActivity {
  id        String   @id @default(uuid())
  userId    String
  type      String   // INTERVIEW | CODING_PROBLEM | RESUME_ANALYSIS | ROADMAP_TASK
  metadata  Json?    // { score, problemId, sessionId, etc. }
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type])
}

model Assessment {
  id             String   @id @default(uuid())
  title          String
  description    String
  type           String   // APTITUDE | DSA | CORE_CS | COMPANY_SPECIFIC | FULL_PLACEMENT
  duration       Int      // minutes
  totalQuestions Int      @default(0)
  totalMarks     Int      @default(0)
  passingMarks   Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  questions AssessmentQuestion[]
  attempts  AssessmentAttempt[]
}

model AssessmentQuestion {
  id           String   @id @default(uuid())
  assessmentId String
  questionType String   // MCQ | CODING
  questionData Json     // { text, options, correctAnswer, explanation } for MCQ
                        // { title, description, constraints, sampleInput, sampleOutput, testCases, starterCode } for CODING
  difficulty   String   // EASY | MEDIUM | HARD
  topic        String
  marks        Int      @default(1)
  orderIndex   Int

  assessment Assessment          @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers    AssessmentAnswer[]
}

model AssessmentAttempt {
  id            String    @id @default(uuid())
  userId        String
  assessmentId  String
  status        String    // IN_PROGRESS | SUBMITTED | EVALUATED
  score         Int?
  totalMarks    Int?
  accuracy      Float?
  startedAt     DateTime  @default(now())
  submittedAt   DateTime?
  timeTaken     Int?      // seconds
  sectionScores Json?     // [{ section, score, total }]
  strengths     String[]  @default([])
  weaknesses    String[]  @default([])
  suggestions   Json?     // [{ area, suggestion }]

  assessment Assessment          @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers    AssessmentAnswer[]
}

model AssessmentAnswer {
  id            String  @id @default(uuid())
  attemptId     String
  questionId    String
  answer        String? // selected option label or submitted code
  isCorrect     Boolean?
  marksObtained Float?
  reviewed      Boolean @default(false)
  timeSpent     Int?    // seconds

  attempt  AssessmentAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}
